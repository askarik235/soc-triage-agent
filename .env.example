# SOC Triage Assistant - Backend Environment Variables
# Copy this file to ".env" and fill in your own values:  cp .env.example .env

# Your Napster Omniagent API key (from developers.napster.com)
NAPSTER_API_KEY=your_napster_api_key_here

# The agent ID printed by scripts/setup-agent.js after you run it once
AGENT_ID=your_agent_id_here

# Shared secret between the backend and Napster's tool calls (any random string)
TOOL_SECRET=your_random_tool_secret_here

# Shared secret between backend and frontend. MUST match VITE_CLIENT_KEY in frontend/.env
CLIENT_KEY=your_random_client_key_here

# Port the backend listens on
PORT=3001

# Comma-separated allowed frontend origins for CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174